{
  "name": "@briansunter/nib-images",
  "version": "0.1.0",
  "description": "Static, responsive image optimization for Nib.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": ["dist", "README.md"],
  "peerDependencies": {
    "@briansunter/nib": "^0.8.0",
    "react": "^19.2.0"
  },
  "dependencies": {
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@briansunter/nib": "file:../.."
  },
  "scripts": {
    "build": "vite build --config vite.config.ts && tsc --project tsconfig.build.json && node scripts/postbuild-types.mjs",
    "benchmark": "node scripts/benchmark.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  }
}
