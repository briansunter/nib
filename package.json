{
  "name": "@briansunter/nib",
  "version": "0.2.0",
  "packageManager": "bun@1.3.3",
  "description": "A small static-site starter for React, Markdown, and opt-in islands.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briansunter/nib.git"
  },
  "files": [
    "src",
    "scripts",
    "skills",
    "docs",
    "CHANGELOG.md",
    "bun.lock",
    "server.ts",
    "index.html",
    "vite.config.ts",
    "vitest.config.ts",
    "tsconfig.json"
  ],
  "keywords": [
    "static-site",
    "vite",
    "react",
    "islands",
    "markdown",
    "tailwind",
    "ssr"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "bun run typecheck && bun run build:client && bun run build:server && bun run prerender",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --outDir dist/server --ssr src/entry-server.tsx",
    "prerender": "tsx scripts/prerender.ts",
    "preview": "vite preview --outDir dist/client",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:version-policy": "tsx scripts/check-version-policy.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^6.0.3",
    "express": "^5.2.1",
    "gray-matter": "^4.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.20.6",
    "unified": "^11.0.5",
    "vite": "^8.1.5",
    "@tailwindcss/typography": "^0.5.19"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
