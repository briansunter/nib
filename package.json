{
  "name": "@briansunter/nib",
  "version": "0.5.0",
  "packageManager": "bun@1.3.3",
  "description": "A static-site framework for React, Markdown, and opt-in islands.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/briansunter/nib.git"
  },
  "bin": {
    "nib": "./bin/nib.js"
  },
  "exports": {
    ".": {
      "types": "./dist/framework/index.d.ts",
      "import": "./dist/framework/index.js"
    },
    "./internal/client": {
      "types": "./dist/framework/runtime/client.d.ts",
      "import": "./dist/framework/internal/client.js"
    },
    "./internal/server": {
      "types": "./dist/framework/runtime/server.d.ts",
      "import": "./dist/framework/internal/server.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "bin",
    "dist/framework",
    "templates",
    "skills",
    "docs",
    "CHANGELOG.md",
    "README.md"
  ],
  "keywords": [
    "static-site",
    "vite",
    "react",
    "islands",
    "markdown",
    "tailwind",
    "ssr"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "type": "module",
  "scripts": {
    "dev": "bun run build:framework && node bin/nib.js dev --root examples/docs",
    "build": "bun run build:framework && bun run build:docs",
    "build:docs": "node bin/nib.js build --root examples/docs",
    "build:framework": "vite build --config vite.framework.config.ts && tsc --project tsconfig.build.json",
    "test": "bun run build:framework && vitest run --coverage --exclude tests/package-consumer.test.ts && vitest run tests/package-consumer.test.ts --no-coverage",
    "preview": "node bin/nib.js preview --root examples/docs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:version-policy": "tsx scripts/check-version-policy.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.3",
    "@vitejs/plugin-react": "^6.0.3",
    "gray-matter": "^4.0.3",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "tailwindcss": "^4.3.3",
    "unified": "^11.0.5",
    "vite": "^8.1.5",
    "@tailwindcss/typography": "^0.5.19"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
